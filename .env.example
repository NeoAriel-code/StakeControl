# Database Connection
DATABASE_URL="file:./dev.db"

# Auth
AUTH_SECRET="stakecontrol-local-dev-secret"

# Application Config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Optional private QA controls. Only the listed accounts can switch their own plan.
PLAN_TESTER_EMAILS=""

# Private QA accounts allowed to generate demo records.
DEMO_DATA_EMAILS=""

# Transactional mail (Resend). EMAIL_FROM remains accepted as a legacy alias for EMAIL_DEFAULT_FROM.
EMAIL_PROVIDER="resend"
RESEND_API_KEY=""
EMAIL_FROM=""
EMAIL_DEFAULT_FROM=""
EMAIL_SECURITY_FROM=""
EMAIL_ALERTS_FROM=""
EMAIL_REPORTS_FROM=""
EMAIL_REPLY_TO=""
RESEND_WEBHOOK_SECRET=""

# OCR: "mock" | "tesseract" | "google_vision" | "aws_textract" | "azure_vision"
OCR_PROVIDER="mock"
TESSERACT_BIN="tesseract"
TESSERACT_LANG="spa+eng"
GOOGLE_VISION_API_KEY=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AZURE_VISION_ENDPOINT=""
AZURE_VISION_KEY=""

# AI Integration Service. Keep mock for local development without an API key.
AI_PROVIDER="mock" # "mock" | "openai"
OPENAI_API_KEY=""
AI_TICKET_PRIMARY_MODEL="gpt-5-mini"
AI_TICKET_EXPERIMENT_MODEL="gpt-5.6-luna"
AI_TICKET_FALLBACK_MODEL="gpt-5.6-terra"
AI_REPORT_PRIMARY_MODEL="gpt-5-mini"
AI_REPORT_FALLBACK_MODEL="gpt-5.6-terra"
AI_INTERNAL_REVIEW_MODEL="gpt-5.6-sol"
