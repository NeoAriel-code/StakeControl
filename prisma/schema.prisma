generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

enum BetType {
  SINGLE
  COMBO
  BET_BUILDER
  SYSTEM
  LIVE
  PREMATCH
  UNKNOWN
}

enum BetResult {
  PENDING
  WON
  LOST
  VOID
  CASHOUT
  UNKNOWN
}

enum AlertType {
  LIMIT_APPROACHING
  LIMIT_EXCEEDED
  STAKE_INCREASE
  LOSS_STREAK
  HIGH_FREQUENCY
  PAUSE_RECOMMENDED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
}

enum PlanType {
  FREE
  PREMIUM_MONTHLY
  PREMIUM_ANNUAL
}

enum OddsFormat {
  DECIMAL
  AMERICAN
}

model User {
  id                     String                   @id @default(cuid())
  email                  String                   @unique
  passwordHash           String                   @default("")
  name                   String?
  country                String?
  preferredSports        String?
  ageConfirmed           Boolean                  @default(false)
  termsAcceptedAt        DateTime?
  responsibleGamingAcceptedAt DateTime?
  onboardingCompletedAt  DateTime?
  bankroll               Decimal?
  currency               String                   @default("USD")
  timezone               String                   @default("America/Santiago")
  oddsFormat             OddsFormat               @default(DECIMAL)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  bets                   Bet[]
  betTicketImages        BetTicketImage[]
  limits                 UserLimits?
  alerts                 ResponsibleGamingAlert[]
  subscriptions          Subscription[]
  monthlyReports         MonthlyReport[]

  @@index([createdAt])
}

model Bet {
  id                String            @id @default(cuid())
  userId            String
  title             String
  description       String?
  sportsbook        String?
  ticketCode        String?
  sport             String?
  league            String?
  market            String?
  selection         String?
  currency          String            @default("USD")
  betType           BetType           @default(UNKNOWN)
  result            BetResult         @default(PENDING)
  stake             Decimal
  odds              Decimal
  potentialPayout   Decimal?
  settledPayout     Decimal?
  profitLoss        Decimal?
  placedAt          DateTime
  settledAt         DateTime?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketImages      BetTicketImage[]
  legs              BetLeg[]

  @@index([userId, placedAt])
  @@index([userId, result])
}

model BetLeg {
  id        String    @id @default(cuid())
  betId     String
  position  Int
  event     String
  sport     String?
  league    String?
  market    String?
  selection String?
  odds      Decimal?
  result    BetResult @default(PENDING)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bet       Bet       @relation(fields: [betId], references: [id], onDelete: Cascade)

  @@unique([betId, position])
  @@index([betId])
}

model BetTicketImage {
  id              String        @id @default(cuid())
  userId          String
  betId           String?
  imageUrl        String
  fileName        String?
  mimeType        String?
  fileSizeBytes   Int?
  uploadedAt      DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bet             Bet?          @relation(fields: [betId], references: [id], onDelete: SetNull)
  aiExtraction    AIExtraction?

  @@index([userId, uploadedAt])
  @@index([betId])
}

model AIExtraction {
  id                String         @id @default(cuid())
  betTicketImageId  String         @unique
  provider          String?
  model             String?
  status            String         @default("completed")
  confidence        Decimal?
  rawText           String?
  extractedData     Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  betTicketImage    BetTicketImage @relation(fields: [betTicketImageId], references: [id], onDelete: Cascade)
}

model UserLimits {
  id                   String    @id @default(cuid())
  userId               String    @unique
  dailyStakeLimit      Decimal?
  weeklyStakeLimit     Decimal?
  monthlyStakeLimit    Decimal?
  maxStakePerBet       Decimal?
  monthlyLossLimit     Decimal?
  pauseUntil           DateTime?
  coolingOffUntil      DateTime?
  pauseAllBetting      Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResponsibleGamingAlert {
  id             String         @id @default(cuid())
  userId         String
  type           AlertType
  severity       AlertSeverity
  title          String
  message        String
  acknowledgedAt DateTime?
  metadata       Json?
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, severity])
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String
  planType           PlanType  @default(FREE)
  status             String    @default("active")
  externalCustomerId String?
  externalSubId      String?
  startedAt          DateTime  @default(now())
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model MonthlyReport {
  id             String    @id @default(cuid())
  userId         String
  year           Int
  month          Int
  totalBets      Int       @default(0)
  totalStake     Decimal   @default(0)
  totalProfit    Decimal   @default(0)
  roi            Decimal   @default(0)
  hitRate        Decimal?
  netUnits       Decimal?
  analysisData   Json?
  safePromptVersion String?
  analysisGeneratedAt DateTime?
  generatedAt    DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId, year, month])
}
