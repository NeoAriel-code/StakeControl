generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlite"
}

enum BetType {
  SINGLE
  COMBO
  BET_BUILDER
  SYSTEM
  LIVE
  PREMATCH
  UNKNOWN
}

enum BetResult {
  PENDING
  WON
  LOST
  VOID
  CASHOUT
  UNKNOWN
}

enum FieldSource {
  USER
  OCR
  INFERRED
  UNKNOWN
}

enum AlertType {
  LIMIT_APPROACHING
  LIMIT_EXCEEDED
  STAKE_INCREASE
  LOSS_STREAK
  HIGH_FREQUENCY
  PAUSE_RECOMMENDED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
}

enum EmailDeliveryKind {
  WELCOME
  EMAIL_VERIFICATION
  PASSWORD_RESET
  PASSWORD_CHANGED
  RESPONSIBLE_GAMING_ALERT
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum PlanType {
  FREE
  PREMIUM_MONTHLY
  PREMIUM_ANNUAL
}

enum OddsFormat {
  DECIMAL
  AMERICAN
}

model User {
  id                     String                   @id @default(cuid())
  email                  String                   @unique
  passwordHash           String                   @default("")
  name                   String?
  country                String?
  preferredSports        String?
  ageConfirmed           Boolean                  @default(false)
  termsAcceptedAt        DateTime?
  responsibleGamingAcceptedAt DateTime?
  onboardingCompletedAt  DateTime?
  bankroll               Decimal?
  currency               String                   @default("USD")
  timezone               String                   @default("America/Santiago")
  oddsFormat             OddsFormat               @default(DECIMAL)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  emailVerifiedAt        DateTime?
  bets                   Bet[]
  betTicketImages        BetTicketImage[]
  limits                 UserLimits?
  alerts                 ResponsibleGamingAlert[]
  subscriptions          Subscription[]
  monthlyReports         MonthlyReport[]
  passwordResetTokens    PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  notificationPreferences NotificationPreferences?
  emailDeliveries        EmailDelivery[]
  accountSecurityAlerts  AccountSecurityAlert[]

  @@index([createdAt])
}

model Bet {
  id                String            @id @default(cuid())
  userId            String
  creationKey       String?
  title             String
  description       String?
  sportsbook        String?
  ticketCode        String?
  sport             String?
  league            String?
  market            String?
  selection         String?
  currency          String            @default("USD")
  betType           BetType           @default(UNKNOWN)
  result            BetResult         @default(PENDING)
  stake             Decimal
  odds              Decimal
  potentialPayout   Decimal?
  settledPayout     Decimal?
  profitLoss        Decimal?
  placedAt          DateTime?
  eventStartAt      DateTime?
  placedAtSource    FieldSource?
  eventStartAtSource FieldSource?
  currencySource    FieldSource?
  settledAt         DateTime?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketImages      BetTicketImage[]
  legs              BetLeg[]

  @@index([userId, placedAt])
  @@index([userId, result])
  @@unique([userId, creationKey])
}

model BetLeg {
  id        String    @id @default(cuid())
  betId     String
  position  Int
  event     String
  sport     String?
  league    String?
  market    String?
  selection String?
  odds      Decimal?
  result    BetResult @default(PENDING)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  bet       Bet       @relation(fields: [betId], references: [id], onDelete: Cascade)

  @@unique([betId, position])
  @@index([betId])
}

model RateLimitBucket {
  key       String   @id
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model BetTicketImage {
  id              String        @id @default(cuid())
  userId          String
  betId           String?
  imageUrl        String
  fileName        String?
  mimeType        String?
  fileSizeBytes   Int?
  uploadedAt      DateTime      @default(now())
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bet             Bet?          @relation(fields: [betId], references: [id], onDelete: SetNull)
  aiExtraction    AIExtraction?

  @@index([userId, uploadedAt])
  @@index([betId])
}

model AIExtraction {
  id                String         @id @default(cuid())
  betTicketImageId  String         @unique
  provider          String?
  model             String?
  status            String         @default("completed")
  confidence        Decimal?
  rawText           String?
  extractedData     Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  betTicketImage    BetTicketImage @relation(fields: [betTicketImageId], references: [id], onDelete: Cascade)
}

model UserLimits {
  id                   String    @id @default(cuid())
  userId               String    @unique
  dailyStakeLimit      Decimal?
  weeklyStakeLimit     Decimal?
  monthlyStakeLimit    Decimal?
  maxStakePerBet       Decimal?
  monthlyLossLimit     Decimal?
  pauseUntil           DateTime?
  coolingOffUntil      DateTime?
  pauseAllBetting      Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResponsibleGamingAlert {
  id             String         @id @default(cuid())
  userId         String
  type           AlertType
  severity       AlertSeverity
  title          String
  message        String
  acknowledgedAt DateTime?
  metadata       Json?
  createdAt      DateTime       @default(now())
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailDeliveries EmailDelivery[]

  @@index([userId, createdAt])
  @@index([userId, severity])
}

model NotificationPreferences {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  emailAlertsEnabled     Boolean  @default(false)
  limitApproachingEnabled Boolean @default(false)
  limitExceededEnabled   Boolean  @default(false)
  stakeIncreaseEnabled   Boolean  @default(false)
  lossStreakEnabled      Boolean  @default(false)
  highFrequencyEnabled   Boolean  @default(false)
  pauseRecommendedEnabled Boolean @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailDelivery {
  id                String              @id @default(cuid())
  userId            String
  alertId           String?
  dedupeKey         String              @unique
  kind              EmailDeliveryKind
  status            EmailDeliveryStatus @default(PENDING)
  providerMessageId String?             @unique
  recipientHash     String?
  lastEvent         String?
  deliveredAt       DateTime?
  bouncedAt         DateTime?
  complainedAt      DateTime?
  failedAt          DateTime?
  delayedAt         DateTime?
  failureReason     String?
  sentAt            DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert             ResponsibleGamingAlert? @relation(fields: [alertId], references: [id], onDelete: Cascade)
  securityAlert     AccountSecurityAlert?

  @@index([userId, createdAt])
  @@index([alertId])
  @@index([recipientHash])
}

model EmailWebhookEvent {
  id                String   @id @default(cuid())
  providerEventId   String   @unique
  eventType         String
  providerMessageId String?
  createdAt         DateTime @default(now())

  @@index([providerMessageId])
}

model RestrictedEmailAddress {
  id        String   @id @default(cuid())
  emailHash String   @unique
  reason    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AccountSecurityAlert {
  id         String        @id @default(cuid())
  userId     String
  deliveryId String        @unique
  kind       String
  occurredAt DateTime
  createdAt  DateTime      @default(now())
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  delivery   EmailDelivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)

  @@index([userId, occurredAt])
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String
  planType           PlanType  @default(FREE)
  status             String    @default("active")
  externalCustomerId String?
  externalSubId      String?
  startedAt          DateTime  @default(now())
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model MonthlyReport {
  id             String    @id @default(cuid())
  userId         String
  year           Int
  month          Int
  totalBets      Int       @default(0)
  totalStake     Decimal   @default(0)
  totalProfit    Decimal   @default(0)
  roi            Decimal   @default(0)
  hitRate        Decimal?
  netUnits       Decimal?
  analysisData   Json?
  safePromptVersion String?
  analysisGeneratedAt DateTime?
  generatedAt    DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, month])
  @@index([userId, year, month])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}
